    artist: 'Eder Machado',
    cover: 'https://imagestore.ffm.to/link/69f888bb2c00003300296abe/6a083afc3100003600eb82ea_14fe9b56d4a52b11f34ef030cd186e75.jpeg',
    spotify: 'https://open.spotify.com/track/5AtObetp8x0ojlEYdOHwpA',
    apple: 'https://geo.music.apple.com/au/album/do-vale-ao-monte/6769353647?i=6769353654',
