    youtube: 'https://www.youtube.com/watch?v=LFk7ycNWVZA',
  },
];

const destaque = releases[0];
const demaisReleases = releases.slice(1);

// clipes oficiais reais do canal (confirmados 17/07, ver emmusicproducoes.com.br)
const clipes = [
  {
    title: 'Não Estamos Sós (Clipe Oficial)',
    thumb: 'https://i.ytimg.com/vi/ZzxnoQomcc0/maxresdefault.jpg',
    url: 'https://www.youtube.com/watch?v=ZzxnoQomcc0',
  },
  {
    title: 'Acorda pra Vida (Clipe Oficial)',
    thumb: 'https://i.ytimg.com/vi/YFYyF1Mrvww/maxresdefault.jpg',
    url: 'https://www.youtube.com/watch?v=YFYyF1Mrvww',
  },
  {
    title: 'Fechado com Cristo',
    thumb: 'https://i.ytimg.com/vi/HZFECGdnPBk/maxresdefault.jpg',
    url: 'https://www.youtube.com/watch?v=HZFECGdnPBk',
  },
  {
    title: 'Desesperado (Clipe Oficial)',
    thumb: 'https://i.ytimg.com/vi/1Bi34Cl2PXQ/maxresdefault.jpg',
    url: 'https://www.youtube.com/watch?v=1Bi34Cl2PXQ',
  },
];

const structuredData = {
  '@context': 'https://schema.org',
  '@type': 'MusicGroup',
  name: 'Eder Machado',
  alternateName: 'Prod. Eder Machado',
  genre: ['Gospel', 'Sertanejo Gospel'],
  url: 'https://eder.edtmusic.com.br',
  image: 'https://eder.edtmusic.com.br/images/eder-avatar.png',
  description:
    'Eder Machado é cantor de gospel e sertanejo gospel, produtor fonográfico, compositor, ' +
    'arranjador e instrutor de música. Fundador da ED Tutoriais e da EM Music Produções, sócio ' +
    'da Rede Loops Brasil. Seus loops e instrumentos virtuais já foram usados em produções da ' +
    'Netflix, do SBT e em hits como "Zona de Perigo" (Léo Santana).',
  sameAs: [YOUTUBE_TOPICO, YOUTUBE_EMMUSIC],
  album: releases.map((r) => ({
    '@type': 'MusicAlbum',
    name: r.title,
    byArtist: r.artist,
  })),
};
---
<Base
  title="Eder Machado - Prod. Eder Machado | Música e lançamentos"
  description="Ouça as últimas músicas do Eder Machado (Prod. Eder Machado): singles, clipes oficiais e links pra Spotify, Apple Music, Deezer e YouTube."
  image="/images/eder-avatar.png"
  structuredData={structuredData}
>
  <main>
    <!-- HERO: música do momento -->
    <section class="relative overflow-hidden px-6 pt-14 pb-14 sm:pt-20">
      <div
        class="pointer-events-none absolute -right-24 -top-24 h-72 w-72 rounded-full bg-brand-orange/15 blur-3xl"
        aria-hidden="true"
      >
      </div>
      <div class="relative mx-auto max-w-xl text-center">
        <img
          src="/images/eder-avatar.png"
          alt="Prod. Eder Machado"
          class="mx-auto h-16 w-auto sm:h-20"
          width="571"
          height="365"
        />

        <div class="mx-auto mt-5 flex h-8 items-end justify-center gap-1" aria-hidden="true">
          <span class="eq-bar w-1.5 rounded-full bg-brand-orange"></span>
          <span class="eq-bar w-1.5 rounded-full bg-brand-orange"></span>
          <span class="eq-bar w-1.5 rounded-full bg-brand-orange"></span>
          <span class="eq-bar w-1.5 rounded-full bg-brand-orange"></span>
          <span class="eq-bar w-1.5 rounded-full bg-brand-orange"></span>
        </div>

        <h1 class="balance mt-5 font-display text-4xl leading-[0.95] text-paper sm:text-5xl">
          EDER MACHADO
        </h1>
      </div>
    </section>

    <!-- MÚSICA DO MOMENTO -->
    <section class="px-6 pb-14">
      <div class="mx-auto max-w-3xl">
        <p class="text-xs font-semibold uppercase tracking-[0.2em] text-brand-orange">
          Música do momento
        </p>
        <h2 class="mt-2 font-display text-2xl text-paper sm:text-3xl">{destaque.title}</h2>
        <p class="mt-1 text-sm text-paper/50">{destaque.artist}</p>

        <div
          class="video-facade group relative mt-6 block aspect-video w-full cursor-pointer overflow-hidden rounded-2xl border border-ink-line bg-ink-raised"
          data-youtube-id={destaque.clipeOficialId}
          role="button"
          tabindex="0"
          aria-label={`Assistir o clipe de ${destaque.title}`}
        >
          <img
            src={`https://i.ytimg.com/vi/${destaque.clipeOficialId}/maxresdefault.jpg`}
            alt={`Trecho do clipe de ${destaque.title}`}
            loading="eager"
            class="h-full w-full object-cover"
          />
          <span class="pointer-events-none absolute inset-0 bg-gradient-to-t from-ink/70 via-ink/0 to-ink/0"></span>
          <span class="video-play-btn pointer-events-none absolute inset-0 flex items-center justify-center">
            <span class="flex h-16 w-16 items-center justify-center rounded-full bg-brand-orange">
              <svg viewBox="0 0 24 24" class="ml-1 h-7 w-7 fill-ink"><path d="M8 5v14l11-7z" /></svg>
            </span>
          </span>
        </div>

        <div class="mt-5 flex flex-wrap justify-center gap-2">
          <a
            href={destaque.spotify}
            target="_blank"
            rel="noopener noreferrer"
            class="flex items-center gap-1.5 rounded-full border border-ink-line py-1.5 pl-1.5 pr-3 text-xs font-semibold text-paper/70 transition hover:border-brand-orange hover:text-paper"
          >
            <img src={PLATFORM_LOGOS.spotify} alt="" class="h-4 w-4" loading="lazy" />
            Spotify
          </a>
          <a
            href={destaque.apple}
            target="_blank"
            rel="noopener noreferrer"
            class="flex items-center gap-1.5 rounded-full border border-ink-line py-1.5 pl-1.5 pr-3 text-xs font-semibold text-paper/70 transition hover:border-brand-orange hover:text-paper"
          >
            <img src={PLATFORM_LOGOS.apple} alt="" class="h-4 w-4" loading="lazy" />
            Apple Music
          </a>
          <a
            href={destaque.deezer}
            target="_blank"
            rel="noopener noreferrer"
            class="flex items-center gap-1.5 rounded-full border border-ink-line py-1.5 pl-1.5 pr-3 text-xs font-semibold text-paper/70 transition hover:border-brand-orange hover:text-paper"
          >
            <img src={PLATFORM_LOGOS.deezer} alt="" class="h-4 w-4" loading="lazy" />
            Deezer
          </a>
          <a
            href={destaque.youtube}
            target="_blank"
            rel="noopener noreferrer"
            class="flex items-center gap-1.5 rounded-full border border-ink-line py-1.5 pl-1.5 pr-3 text-xs font-semibold text-paper/70 transition hover:border-brand-orange hover:text-paper"
          >
            <img src={PLATFORM_LOGOS.youtube} alt="" class="h-4 w-4" loading="lazy" />
            YouTube
          </a>
        </div>
      </div>
    </section>

    <!-- ÚLTIMOS LANÇAMENTOS -->
    <section class="px-6 py-14">
      <div class="mx-auto max-w-4xl">
        <h2 class="font-display text-3xl text-paper">Últimos lançamentos</h2>
        <p class="mt-2 text-sm text-paper/60">Ouça direto nas plataformas digitais.</p>

        <div class="mt-8 flex snap-x snap-mandatory justify-center gap-4 overflow-x-auto pb-4">
          {demaisReleases.map((r) => (
            <div class="glow-card flex w-56 shrink-0 snap-start flex-col overflow-hidden rounded-2xl border border-ink-line bg-ink-raised">
              <span class="relative block aspect-square w-full overflow-hidden">
                <img
                  src={r.cover}
                  alt={`Capa de ${r.title}`}
                  loading="lazy"
                  class="h-full w-full object-cover"
                />
              </span>
              <div class="p-4">
                <p class="font-display text-lg leading-tight text-paper">{r.title}</p>
                <p class="mt-1 text-xs text-paper/50">{r.artist}</p>
                <div class="mt-3 flex flex-wrap gap-1.5">
                  <a
                    href={r.spotify}
                    target="_blank"
                    rel="noopener noreferrer"
                    aria-label={`Ouvir ${r.title} no Spotify`}
                    class="flex items-center gap-1.5 rounded-full border border-ink-line py-1 pl-1 pr-2.5 text-[11px] font-semibold text-paper/70 transition hover:border-brand-orange hover:text-paper"
                  >
                    <img src={PLATFORM_LOGOS.spotify} alt="" class="h-4 w-4" loading="lazy" />
                    Spotify
                  </a>
                  <a
                    href={r.apple}
                    target="_blank"
                    rel="noopener noreferrer"
                    aria-label={`Ouvir ${r.title} no Apple Music`}
                    class="flex items-center gap-1.5 rounded-full border border-ink-line py-1 pl-1 pr-2.5 text-[11px] font-semibold text-paper/70 transition hover:border-brand-orange hover:text-paper"
                  >
                    <img src={PLATFORM_LOGOS.apple} alt="" class="h-4 w-4" loading="lazy" />
                    Apple Music
                  </a>
                  <a
                    href={r.deezer}
                    target="_blank"
                    rel="noopener noreferrer"
                    aria-label={`Ouvir ${r.title} no Deezer`}
                    class="flex items-center gap-1.5 rounded-full border border-ink-line py-1 pl-1 pr-2.5 text-[11px] font-semibold text-paper/70 transition hover:border-brand-orange hover:text-paper"
                  >
                    <img src={PLATFORM_LOGOS.deezer} alt="" class="h-4 w-4" loading="lazy" />
                    Deezer
                  </a>
                  <a
                    href={r.youtube}
                    target="_blank"
                    rel="noopener noreferrer"
                    aria-label={`Assistir ${r.title} no YouTube`}
                    class="flex items-center gap-1.5 rounded-full border border-ink-line py-1 pl-1 pr-2.5 text-[11px] font-semibold text-paper/70 transition hover:border-brand-orange hover:text-paper"
                  >
                    <img src={PLATFORM_LOGOS.youtube} alt="" class="h-4 w-4" loading="lazy" />
                    YouTube
                  </a>
                </div>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- CLIPES -->
    <section class="px-6 py-14">
      <div class="mx-auto max-w-4xl">
        <h2 class="font-display text-3xl text-paper">Clipes</h2>
        <p class="mt-2 text-sm text-paper/60">Direto do canal, sem imagem de banco.</p>

        <div class="mt-8 grid gap-4 sm:grid-cols-2 lg:grid-cols-4">
          {clipes.map((c) => (
            <a
              href={c.url}
              target="_blank"
              rel="noopener noreferrer"
              class="glow-card group relative block overflow-hidden rounded-2xl border border-ink-line bg-ink-raised"
            >
              <span class="relative block aspect-video w-full overflow-hidden">
                <img
                  src={c.thumb}
                  alt={c.title}
                  loading="lazy"
                  class="h-full w-full object-cover"
                />
                <span class="pointer-events-none absolute inset-0 bg-gradient-to-t from-ink/80 via-ink/0 to-ink/0" />
                <span class="absolute inset-0 flex items-center justify-center">
                  <span class="flex h-11 w-11 items-center justify-center rounded-full bg-ink/70 ring-1 ring-paper/40">
                    <svg viewBox="0 0 24 24" class="ml-0.5 h-4 w-4 fill-paper"><path d="M8 5v14l11-7z" /></svg>
                  </span>
                </span>
              </span>
              <p class="p-4 text-sm font-semibold text-paper">{c.title}</p>
              <span class="sr-only"> (abre no YouTube em nova aba)</span>
            </a>
          ))}
        </div>

        <div class="mt-8 flex flex-wrap items-center gap-x-8 gap-y-3">
          <span class="text-sm text-paper/50">Ver mais:</span>
          <a
            href={YOUTUBE_TOPICO}
            target="_blank"
            rel="noopener noreferrer"
            class="text-sm font-semibold text-brand-orange hover:text-paper"
          >
            Canal Prod. Eder Machado<span class="sr-only"> (abre no YouTube em nova aba)</span>
          </a>
          <a
            href={YOUTUBE_EMMUSIC}
            target="_blank"
            rel="noopener noreferrer"
            class="text-sm font-semibold text-brand-orange hover:text-paper"
          >
            Canal EM Music Produções<span class="sr-only"> (abre no YouTube em nova aba)</span>
          </a>
        </div>
      </div>
    </section>

    <!-- PERFIL DO ARTISTA -->
    <section class="px-6 py-14">
      <div class="mx-auto max-w-2xl rounded-2xl border border-ink-line bg-ink-raised p-8 text-center">
        <img
          src="/images/eder-foto.png"
          alt="Eder Machado"
          class="mx-auto h-24 w-24 rounded-full object-cover"
          width="331"
          height="335"
          loading="lazy"
        />
        <h2 class="mt-4 font-display text-2xl text-paper">Quem é o Eder Machado</h2>
        <p class="mt-4 text-sm leading-relaxed text-paper/70">
          Eder Machado produz e canta música gospel e sertanejo gospel, com single novo saindo
          quase todo mês. Também é o produtor por trás da EM Music Produções, gravando,
          mixando e masterizando pra outros artistas. Cada lançamento vai pras plataformas
          digitais e ganha clipe oficial no canal.
        </p>
        <p class="mt-4 text-sm leading-relaxed text-paper/70">
          Fora do microfone, é fundador da ED Tutoriais e sócio da Rede Loops Brasil. Os loops e
          instrumentos virtuais que ele desenvolveu já foram usados em produções da Netflix, do
          SBT e em hits como "Zona de Perigo", do Léo Santana. Também dá aula: ensina produção
          musical do jeito que vive no dia a dia, sem enrolação.
        </p>
      </div>
    </section>

  </main>

  <script>
    const facade = document.querySelector<HTMLElement>('.video-facade');
    facade?.addEventListener('click', () => {
      const videoId = facade.dataset.youtubeId;
      if (!videoId) return;
      const iframe = document.createElement('iframe');
      iframe.src = `https://www.youtube.com/embed/${videoId}?autoplay=1`;
      iframe.className = 'absolute inset-0 h-full w-full';
      iframe.allow = 'accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture';
      iframe.allowFullscreen = true;
      facade.innerHTML = '';
      facade.appendChild(iframe);
    });
    facade?.addEventListener('keydown', (e) => {
      if (e.key === 'Enter' || e.key === ' ') {
        e.preventDefault();
        facade.click();
      }
    });
  </script>
</Base>
