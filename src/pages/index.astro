---
import Base from '../layouts/Base.astro';
import RedeFooter from '../components/RedeFooter.astro';

const YOUTUBE_TOPICO = 'https://www.youtube.com/@PRODERMACHADO';
const YOUTUBE_EMMUSIC = 'https://www.youtube.com/@emproducooesofficial6670';

// lançamentos reais distribuídos via Ditto Music (mesma fonte confirmada em
// emmusicproducoes.com.br, 17/07), ordenados do mais novo pro mais antigo.
// O primeiro da lista é a "música do momento" em destaque no hero.
const releases = [
  {
    title: 'Não Estamos Sós',
    artist: 'Eder Machado',
    cover: 'https://imagestore.ffm.to/link/69f888bb2c00003300296abe/6a1ee4582c00000e00ac4635_1a50e44a432d66a4987cc5a967da99e0.jpeg',
    spotify: 'https://open.spotify.com/track/5WHnAnfjYAzth66TlOcQgl',
    apple: 'https://geo.music.apple.com/au/album/n%C3%A3o-estamos-s%C3%B3s/6775147902?i=6775147906',
    deezer: 'https://www.deezer.com/track/4055581231',
    youtube: 'https://www.youtube.com/watch?v=awWYAmkYsmE',
    clipeOficialId: 'ZzxnoQomcc0',
  },
  {
    title: 'Do Vale ao Monte',
    artist: 'Eder Machado',
    cover: 'https://imagestore.ffm.to/link/69f888bb2c00003300296abe/6a083afc3100003600eb82ea_14fe9b56d4a52b11f34ef030cd186e75.jpeg',
    spotify: 'https://open.spotify.com/track/5AtObetp8x0ojlEYdOHwpA',
    apple: 'https://geo.music.apple.com/au/album/do-vale-ao-monte/6769353647?i=6769353654',
    deezer: 'https://www.deezer.com/track/4027679111',
    youtube: 'https://www.youtube.com/watch?v=1T2blGbIRjA',
  },
  {
    title: 'Eu Escolho Lutar',
    artist: 'Eder Machado',
    cover: 'https://imagestore.ffm.to/link/69f888bb2c00003300296abe/6a02c73f2d00003300c94297_6d3fd31dfa5463a5b8eb8c78d47863fd.jpeg',
    spotify: 'https://open.spotify.com/track/2q29YnjNtaBSXxTgQa6Jwt',
    apple: 'https://geo.music.apple.com/au/album/eu-escolho-lutar/6767918975?i=6767918976',
    deezer: 'https://www.deezer.com/track/4011663231',
    youtube: 'https://www.youtube.com/watch?v=mkqrOhX8e3U',
  },
  {
    title: 'Fechado com Cristo',
    artist: 'Eder Machado & Steyce',
    cover: 'https://imagestore.ffm.to/link/69f888bb2c00003300296abe/6a083afd3100003600eb82eb_b775905b329cbb51d8dcfdcc6a1231b8.jpeg',
    spotify: 'https://open.spotify.com/track/56DURo3iGO9Eq1akpDDzR7',
    apple: 'https://geo.music.apple.com/au/album/fechado-com-cristo/6770305446?i=6770305447',
    deezer: 'https://www.deezer.com/track/4027047751',
    youtube: 'https://www.youtube.com/watch?v=Zmv0Mja3uDw',
  },
  {
    title: 'Paternidade',
    artist: 'Eder Machado feat. Steyce',
    cover: 'https://imagestore.ffm.to/link/69f888bb2c00003300296abe/6a06e2863300002900a269d3_af184da61246c2584bf30b03be41b836.jpeg',
    spotify: 'https://open.spotify.com/track/75vwMFeHbHO0HCLUrRXRTb',
    apple: 'https://geo.music.apple.com/au/album/paternidade-feat-steyce/6768905593?i=6768905669',
    deezer: 'https://www.deezer.com/track/4018897741',
    youtube: 'https://www.youtube.com/watch?v=M3YQP5N7dHM',
  },
  {
    title: 'Não Espera',
    artist: 'Eder Machado',
    cover: 'https://imagestore.ffm.to/link/69f888bb2c00003300296abe/69fdcb432b00000e0085d212_8b3eb5d2021a4e09b8d95ddbae4b9b32.jpeg',
    spotify: 'https://open.spotify.com/track/5QlIaxHlA5bq310Dcy2Iob',
    apple: 'https://geo.music.apple.com/au/album/n%C3%A3o-espera/6766763652?i=6766763655',
    deezer: 'https://www.deezer.com/track/4004372111',
    youtube: 'https://www.youtube.com/watch?v=fdSo2E2uswc',
  },
  {
    title: 'Desesperado',
    artist: 'Eder Machado',
    cover: 'https://imagestore.ffm.to/link/69f888bb2c00003300296abe/69fdc7dc3300001100a08730_db9f28d1daff1b430a6b42dcdef83a10.jpeg',
    spotify: 'https://open.spotify.com/track/1qmSlh7633CmpGlY2q0F0T',
    apple: 'https://geo.music.apple.com/au/album/desesperado/6766744636?i=6766744639',
    deezer: 'https://www.deezer.com/track/4004288911',
    youtube: 'https://www.youtube.com/watch?v=cc5jUBQ9DjE',
  },
  {
    title: 'Acorda Pra Vida',
    artist: 'Eder Machado',
    cover: 'https://imagestore.ffm.to/link/69f888bb2c00003300296abe/69f888be2b00003c008513cb_1c31000743baa1b4400c30979ed9288a.jpeg',
    spotify: 'https://open.spotify.com/track/3yo8nfbKKyfYkRftw8raAh',
    apple: 'https://geo.music.apple.com/au/album/acorda-pra-vida/6765744044?i=6765744046',
    deezer: 'https://www.deezer.com/track/3997223101',
    youtube: 'https://www.youtube.com/watch?v=LFk7ycNWVZA',
  },
];

// video de fundo do hero: "Acorda Pra Vida", indicado pela Tore 24/07
const HERO_YT_ID = 'LFk7ycNWVZA';
const heroYoutubeEmbed = `https://www.youtube-nocookie.com/embed/${HERO_YT_ID}?autoplay=1&mute=1&loop=1&playlist=${HERO_YT_ID}&controls=0&modestbranding=1&rel=0&showinfo=0&disablekb=1&playsinline=1&iv_load_policy=3`;
const destaque = releases.find((r) => r.youtube.includes(HERO_YT_ID)) || releases[0];
const demaisReleases = releases.filter((r) => r !== destaque);

// clipes oficiais reais do canal (confirmados 17/07, ver emmusicproducoes.com.br)
const clipes = [
  {
    title: 'Não Estamos Sós (Clipe Oficial)',
    thumb: 'https://i.ytimg.com/vi/ZzxnoQomcc0/maxresdefault.jpg',
    url: 'https://www.youtube.com/watch?v=ZzxnoQomcc0',
  },
  {
    title: 'Acorda pra Vida (Clipe Oficial)',
    thumb: 'https://i.ytimg.com/vi/YFYyF1Mrvww/maxresdefault.jpg',
    url: 'https://www.youtube.com/watch?v=YFYyF1Mrvww',
  },
  {
    title: 'Fechado com Cristo',
    thumb: 'https://i.ytimg.com/vi/HZFECGdnPBk/maxresdefault.jpg',
    url: 'https://www.youtube.com/watch?v=HZFECGdnPBk',
  },
  {
    title: 'Desesperado (Clipe Oficial)',
    thumb: 'https://i.ytimg.com/vi/1Bi34Cl2PXQ/maxresdefault.jpg',
    url: 'https://www.youtube.com/watch?v=1Bi34Cl2PXQ',
  },
];

const structuredData = {
  '@context': 'https://schema.org',
  '@type': 'MusicGroup',
  name: 'Eder Machado',
  alternateName: 'Prod. Eder Machado',
  genre: ['Gospel', 'Sertanejo Gospel'],
  url: 'https://eder.edtmusic.com.br',
  image: 'https://eder.edtmusic.com.br/images/eder-avatar.png',
  description:
    'Eder Machado é cantor de gospel e sertanejo gospel, produtor fonográfico, compositor, ' +
    'arranjador e instrutor de música. Fundador da ED Tutoriais e da EM Music Produções, sócio ' +
    'da Rede Loops Brasil. Seus loops e instrumentos virtuais já foram usados em produções da ' +
    'Netflix, do SBT e em hits como "Zona de Perigo" (Léo Santana).',
  sameAs: [YOUTUBE_TOPICO, YOUTUBE_EMMUSIC],
  album: releases.map((r) => ({
    '@type': 'MusicAlbum',
    name: r.title,
    byArtist: r.artist,
  })),
};
---
<Base
  title="Eder Machado - Prod. Eder Machado | Música e lançamentos"
  description="Ouça as últimas músicas do Eder Machado (Prod. Eder Machado): singles, clipes oficiais e links pra Spotify, Apple Music, Deezer e YouTube."
  image="/images/eder-avatar.png"
  structuredData={structuredData}
>
  <main>
    <!-- HERO: video de fundo (Acorda Pra Vida) + single em destaque -->
    <section class="relative flex min-h-[100svh] flex-col items-center justify-center overflow-hidden px-6 py-20">
      <div class="absolute inset-0 overflow-hidden" aria-hidden="true">
        <div class="hero-yt-wrap">
          <iframe
            class="hero-yt-iframe"
            src={heroYoutubeEmbed}
            title=""
            allow="autoplay; encrypted-media"
            tabindex="-1"
          ></iframe>
        </div>
        <div class="absolute inset-0 bg-gradient-to-b from-black/80 via-black/15 to-black"></div>
      </div>

      <div class="relative mx-auto max-w-xl text-center [text-shadow:0_1px_3px_rgba(0,0,0,0.85),0_2px_10px_rgba(0,0,0,0.5)]">
        <img
          src="/images/eder-avatar.png"
          alt="Prod. Eder Machado"
          class="mx-auto h-14 w-auto sm:h-16"
          width="571"
          height="365"
        />

        <div class="mx-auto mt-5 flex h-8 items-end justify-center gap-1" aria-hidden="true">
          <span class="eq-bar w-1.5 rounded-full bg-brand-orange"></span>
          <span class="eq-bar w-1.5 rounded-full bg-brand-orange"></span>
          <span class="eq-bar w-1.5 rounded-full bg-brand-orange"></span>
          <span class="eq-bar w-1.5 rounded-full bg-brand-orange"></span>
          <span class="eq-bar w-1.5 rounded-full bg-brand-orange"></span>
        </div>

        <h1 class="balance mt-5 font-hero text-4xl leading-[1.1] text-white sm:text-5xl">
          EDER MACHADO
        </h1>

        <p class="mt-8 text-xs font-semibold uppercase tracking-[0.2em] text-brand-orange">
          Single em destaque
        </p>
        <h2 class="mt-2 font-display text-2xl font-bold text-white sm:text-3xl">{destaque.title}</h2>
        <p class="mt-1 text-sm text-white/70">{destaque.artist}</p>

        <div class="mt-6 flex items-center justify-center gap-5">
          <a href={destaque.spotify} target="_blank" rel="noopener noreferrer" aria-label={`Ouvir ${destaque.title} no Spotify`} class="text-white transition hover:text-brand-orange">
            <svg viewBox="0 0 24 24" class="h-6 w-6 fill-current"><path d="M12 2a10 10 0 1 0 0 20 10 10 0 0 0 0-20Zm4.59 14.4a.62.62 0 0 1-.86.2c-2.36-1.44-5.33-1.77-8.83-.97a.62.62 0 1 1-.28-1.21c3.83-.88 7.12-.5 9.77 1.12.3.18.4.57.2.86Zm1.22-2.72a.78.78 0 0 1-1.07.26c-2.7-1.66-6.82-2.14-10.02-1.17a.78.78 0 1 1-.45-1.49c3.65-1.1 8.18-.57 11.28 1.33.37.23.49.72.26 1.07Zm.11-2.83c-3.24-1.92-8.59-2.1-11.68-1.16a.93.93 0 1 1-.54-1.78c3.55-1.08 9.44-.87 13.16 1.34a.93.93 0 1 1-.94 1.6Z"/></svg>
          </a>
          <a href={destaque.apple} target="_blank" rel="noopener noreferrer" aria-label={`Ouvir ${destaque.title} no Apple Music`} class="text-white transition hover:text-brand-orange">
            <svg viewBox="0 0 24 24" class="h-6 w-6 fill-current"><path d="M16.4 1.8c.1 1.1-.3 2.2-1 3-.7.8-1.8 1.5-2.9 1.4-.1-1.1.4-2.2 1-3 .8-.8 2-1.4 2.9-1.4Zm3.5 16.4c-.3.7-.6 1.3-1 1.9-.6.9-1.2 1.9-2.2 1.9-.9 0-1.2-.6-2.3-.6s-1.4.6-2.3.6c-.9 0-1.6-.9-2.2-1.8-1.5-2.2-2.6-6.2-1.1-8.9.7-1.3 2-2.2 3.4-2.2 1 0 2 .7 2.6.7.6 0 1.7-.8 2.9-.7.5 0 2 .2 2.9 1.5-.1.1-1.7 1-1.7 3 0 2.4 2.1 3.2 2.1 3.2 0 .1-.3 1.1-1.1 2.4Z"/></svg>
          </a>
          <a href={destaque.deezer} target="_blank" rel="noopener noreferrer" aria-label={`Ouvir ${destaque.title} no Deezer`} class="text-white transition hover:text-brand-orange">
            <svg viewBox="0 0 24 24" class="h-6 w-6 fill-current"><rect x="1" y="14" width="4" height="4"/><rect x="7" y="10" width="4" height="8"/><rect x="13" y="6" width="4" height="12"/><rect x="19" y="2" width="4" height="16"/></svg>
          </a>
          <a href={destaque.youtube} target="_blank" rel="noopener noreferrer" aria-label={`Assistir ${destaque.title} no YouTube`} class="text-white transition hover:text-brand-orange">
            <svg viewBox="0 0 24 24" class="h-6 w-6 fill-current"><path d="M23 12s0-3.6-.46-5.3a2.9 2.9 0 0 0-2-2C18.9 4.2 12 4.2 12 4.2s-6.9 0-8.54.5a2.9 2.9 0 0 0-2 2C1 8.4 1 12 1 12s0 3.6.46 5.3a2.9 2.9 0 0 0 2 2c1.64.5 8.54.5 8.54.5s6.9 0 8.54-.5a2.9 2.9 0 0 0 2-2C23 15.6 23 12 23 12ZM9.75 15.5v-7l6 3.5Z"/></svg>
          </a>
        </div>
      </div>
    </section>

    <!-- ÚLTIMOS LANÇAMENTOS -->
    <section class="px-6 py-14">
      <div class="mx-auto max-w-4xl">
        <p class="text-xs font-semibold uppercase tracking-[0.25em] text-brand-orange">Discografia</p>
        <h2 class="mt-2 font-display text-3xl text-paper">Últimos lançamentos</h2>
        <div class="mt-4 h-px w-16 bg-brand-orange"></div>
        <p class="mt-4 text-sm text-paper/60">Ouça direto nas plataformas digitais.</p>

        <div class="mt-8 flex snap-x snap-mandatory justify-center gap-4 overflow-x-auto pb-4">
          {demaisReleases.map((r) => (
            <div class="media-card group flex w-56 shrink-0 snap-start flex-col overflow-hidden bg-ink-raised">
              <span class="relative block aspect-square w-full overflow-hidden">
                <img
                  src={r.cover}
                  alt={`Capa de ${r.title}`}
                  loading="lazy"
                  class="h-full w-full object-cover transition duration-500 group-hover:scale-105"
                />
                <span class="pointer-events-none absolute inset-0 bg-gradient-to-t from-ink via-ink/10 to-transparent" />
                <span class="absolute inset-x-0 bottom-0 p-4">
                  <p class="font-display text-lg font-semibold leading-tight text-white">{r.title}</p>
                  <span class="mt-2 block h-px w-10 bg-white/50"></span>
                  <p class="mt-2 text-xs uppercase tracking-wide text-white/60">{r.artist}</p>
                </span>
              </span>
              <div class="flex items-center gap-4 px-4 py-3">
                <a href={r.spotify} target="_blank" rel="noopener noreferrer" aria-label={`Ouvir ${r.title} no Spotify`} class="text-white transition hover:text-brand-orange">
                  <svg viewBox="0 0 24 24" class="h-5 w-5 fill-current"><path d="M12 2a10 10 0 1 0 0 20 10 10 0 0 0 0-20Zm4.59 14.4a.62.62 0 0 1-.86.2c-2.36-1.44-5.33-1.77-8.83-.97a.62.62 0 1 1-.28-1.21c3.83-.88 7.12-.5 9.77 1.12.3.18.4.57.2.86Zm1.22-2.72a.78.78 0 0 1-1.07.26c-2.7-1.66-6.82-2.14-10.02-1.17a.78.78 0 1 1-.45-1.49c3.65-1.1 8.18-.57 11.28 1.33.37.23.49.72.26 1.07Zm.11-2.83c-3.24-1.92-8.59-2.1-11.68-1.16a.93.93 0 1 1-.54-1.78c3.55-1.08 9.44-.87 13.16 1.34a.93.93 0 1 1-.94 1.6Z"/></svg>
                </a>
                <a href={r.apple} target="_blank" rel="noopener noreferrer" aria-label={`Ouvir ${r.title} no Apple Music`} class="text-white transition hover:text-brand-orange">
                  <svg viewBox="0 0 24 24" class="h-5 w-5 fill-current"><path d="M16.4 1.8c.1 1.1-.3 2.2-1 3-.7.8-1.8 1.5-2.9 1.4-.1-1.1.4-2.2 1-3 .8-.8 2-1.4 2.9-1.4Zm3.5 16.4c-.3.7-.6 1.3-1 1.9-.6.9-1.2 1.9-2.2 1.9-.9 0-1.2-.6-2.3-.6s-1.4.6-2.3.6c-.9 0-1.6-.9-2.2-1.8-1.5-2.2-2.6-6.2-1.1-8.9.7-1.3 2-2.2 3.4-2.2 1 0 2 .7 2.6.7.6 0 1.7-.8 2.9-.7.5 0 2 .2 2.9 1.5-.1.1-1.7 1-1.7 3 0 2.4 2.1 3.2 2.1 3.2 0 .1-.3 1.1-1.1 2.4Z"/></svg>
                </a>
                <a href={r.deezer} target="_blank" rel="noopener noreferrer" aria-label={`Ouvir ${r.title} no Deezer`} class="text-white transition hover:text-brand-orange">
                  <svg viewBox="0 0 24 24" class="h-5 w-5 fill-current"><rect x="1" y="14" width="4" height="4"/><rect x="7" y="10" width="4" height="8"/><rect x="13" y="6" width="4" height="12"/><rect x="19" y="2" width="4" height="16"/></svg>
                </a>
                <a href={r.youtube} target="_blank" rel="noopener noreferrer" aria-label={`Assistir ${r.title} no YouTube`} class="text-white transition hover:text-brand-orange">
                  <svg viewBox="0 0 24 24" class="h-5 w-5 fill-current"><path d="M23 12s0-3.6-.46-5.3a2.9 2.9 0 0 0-2-2C18.9 4.2 12 4.2 12 4.2s-6.9 0-8.54.5a2.9 2.9 0 0 0-2 2C1 8.4 1 12 1 12s0 3.6.46 5.3a2.9 2.9 0 0 0 2 2c1.64.5 8.54.5 8.54.5s6.9 0 8.54-.5a2.9 2.9 0 0 0 2-2C23 15.6 23 12 23 12ZM9.75 15.5v-7l6 3.5Z"/></svg>
                </a>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- CLIPES -->
    <section class="px-6 py-14">
      <div class="mx-auto max-w-4xl">
        <p class="text-xs font-semibold uppercase tracking-[0.25em] text-brand-orange">Portfólio</p>
        <h2 class="mt-2 font-display text-3xl text-paper">Clipes</h2>
        <div class="mt-4 h-px w-16 bg-brand-orange"></div>
        <p class="mt-4 text-sm text-paper/60">Direto do canal, sem imagem de banco.</p>

        <div class="mt-8 grid gap-4 sm:grid-cols-2 lg:grid-cols-4">
          {clipes.map((c) => (
            <a
              href={c.url}
              target="_blank"
              rel="noopener noreferrer"
              class="media-card group relative block overflow-hidden bg-ink-raised"
            >
              <span class="relative block aspect-video w-full overflow-hidden">
                <img
                  src={c.thumb}
                  alt={c.title}
                  loading="lazy"
                  class="h-full w-full object-cover transition duration-500 group-hover:scale-105"
                />
                <span class="pointer-events-none absolute inset-0 bg-gradient-to-t from-ink via-ink/10 to-transparent" />
                <span class="pointer-events-none absolute inset-0 flex items-center justify-center opacity-90 transition group-hover:opacity-100">
                  <span class="flex h-11 w-11 items-center justify-center rounded-full bg-ink/70 ring-1 ring-paper/40">
                    <svg viewBox="0 0 24 24" class="ml-0.5 h-4 w-4 fill-paper"><path d="M8 5v14l11-7z" /></svg>
                  </span>
                </span>
                <span class="absolute inset-x-0 bottom-0 p-4">
                  <p class="text-sm font-semibold leading-tight text-white">{c.title}</p>
                  <span class="mt-2 block h-px w-10 bg-white/50"></span>
                </span>
              </span>
              <span class="sr-only"> (abre no YouTube em nova aba)</span>
            </a>
          ))}
        </div>

        <div class="mt-8 flex flex-wrap items-center gap-x-8 gap-y-3">
          <span class="text-sm text-paper/50">Ver mais:</span>
          <a
            href={YOUTUBE_TOPICO}
            target="_blank"
            rel="noopener noreferrer"
            class="text-sm font-semibold text-brand-orange hover:text-paper"
          >
            Canal Prod. Eder Machado<span class="sr-only"> (abre no YouTube em nova aba)</span>
          </a>
          <a
            href={YOUTUBE_EMMUSIC}
            target="_blank"
            rel="noopener noreferrer"
            class="text-sm font-semibold text-brand-orange hover:text-paper"
          >
            Canal EM Music Produções<span class="sr-only"> (abre no YouTube em nova aba)</span>
          </a>
        </div>
      </div>
    </section>

    <!-- PERFIL DO ARTISTA -->
    <section class="px-6 py-14">
      <div class="glow-card mx-auto max-w-2xl rounded-2xl bg-ink-raised p-8 text-center">
        <img
          src="/images/eder-foto.png"
          alt="Eder Machado"
          class="mx-auto h-24 w-24 rounded-full object-cover"
          width="331"
          height="335"
          loading="lazy"
        />
        <h2 class="mt-4 font-display text-2xl text-paper">Quem é o Eder Machado</h2>
        <p class="mt-4 text-sm leading-relaxed text-paper/70">
          Eder Machado produz e canta música gospel e sertanejo gospel, com single novo saindo
          quase todo mês. Também é o produtor por trás da EM Music Produções, gravando,
          mixando e masterizando pra outros artistas. Cada lançamento vai pras plataformas
          digitais e ganha clipe oficial no canal.
        </p>
        <p class="mt-4 text-sm leading-relaxed text-paper/70">
          Fora do microfone, é fundador da ED Tutoriais e sócio da Rede Loops Brasil. Os loops e
          instrumentos virtuais que ele desenvolveu já foram usados em produções da Netflix, do
          SBT e em hits como "Zona de Perigo", do Léo Santana. Também dá aula: ensina produção
          musical do jeito que vive no dia a dia, sem enrolação.
        </p>
      </div>
    </section>

    <footer class="px-6 py-10">
      <div class="mx-auto max-w-4xl">
        <RedeFooter />
      </div>
    </footer>
  </main>

  <script>
    const facade = document.querySelector<HTMLElement>('.video-facade');
    facade?.addEventListener('click', () => {
      const videoId = facade.dataset.youtubeId;
      if (!videoId) return;
      const iframe = document.createElement('iframe');
      iframe.src = `https://www.youtube.com/embed/${videoId}?autoplay=1`;
      iframe.className = 'absolute inset-0 h-full w-full';
      iframe.allow = 'accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture';
      iframe.allowFullscreen = true;
      facade.innerHTML = '';
      facade.appendChild(iframe);
    });
    facade?.addEventListener('keydown', (e) => {
      if (e.key === 'Enter' || e.key === ' ') {
        e.preventDefault();
        facade.click();
      }
    });
  </script>
</Base>
