---
import Base from '../layouts/Base.astro';

const YOUTUBE_TOPICO = 'https://www.youtube.com/@PRODERMACHADO';
const YOUTUBE_EMMUSIC = 'https://www.youtube.com/@emproducooesofficial6670';

// logos oficiais de cada plataforma, hospedados pela própria Ditto Music (CDN
// assets.ffm.to), mesma fonte usada em emmusicproducoes.com.br (confirmados 17/07)
const PLATFORM_LOGOS = {
  spotify: 'https://cloudinary-cdn.ffm.to/s--DnYCoqSX--/w_64,h_64,c_limit/f_webp/https%3A%2F%2Fassets.ffm.to%2Fimages%2Flogo%2Fmusic-service_spotify_without_text.png',
  apple: 'https://cloudinary-cdn.ffm.to/s--tXfmuRiI--/w_64,h_64,c_limit/f_webp/https%3A%2F%2Fassets.ffm.to%2Fimages%2Flogo%2Fmusic-service_applemusic_without_text.png',
  deezer: 'https://cloudinary-cdn.ffm.to/s--8rjR1rrJ--/w_64,h_64,c_limit/f_webp/https%3A%2F%2Fassets.ffm.to%2Fimages%2Flogo%2Fmusic-service_deezer_without_text_new.png',
